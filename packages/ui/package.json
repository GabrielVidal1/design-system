{
  "name": "@gabvdl/ui",
  "version": "0.6.0",
  "description": "Gabriel Vidal's personal design system — tree-shakeable React components built on shadcn primitives. Flagship: a full-screen image viewer with zoom, pan and swipe.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GabrielVidal1/design-system.git",
    "directory": "packages/ui"
  },
  "homepage": "https://ui.gabvdl.xyz",
  "bugs": {
    "url": "https://github.com/GabrielVidal1/design-system/issues"
  },
  "keywords": [
    "react",
    "components",
    "design-system",
    "shadcn",
    "tailwind",
    "image-viewer"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "gabvdl-changelog": "./bin/changelog.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./theme.css": "./dist/theme.css",
    "./image-viewer.css": "./dist/image-viewer.css",
    "./virtual-list.css": "./dist/virtual-list.css",
    "./overlay.css": "./dist/overlay.css",
    "./progress.css": "./dist/progress.css",
    "./tooltip.css": "./dist/tooltip.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build && node scripts/copy-css.mjs",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.14.5",
    "clsx": "^2.1.1",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.469.0",
    "react-resizable-panels": "^2.1.9",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^29.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.1",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^4.1.10"
  }
}
